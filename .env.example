# ================================================
# CareerCopilot AI — Environment Variables
# Copy this file to .env and fill in your keys
# ================================================

# ── 1. LLM Provider (REQUIRED — pick one) ───────
LLM_PROVIDER=anthropic

# Anthropic Claude (recommended: fast + cheap for this use case)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (alternative)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── 2. LangSmith (REQUIRED for professor demo) ──
# Sign up free at: https://smith.langchain.com/
# Goes to Settings → API Keys → Create API Key
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=faang-job-hunter

# ── 3. Job Sources ───────────────────────────────
# jobright.ai  → NO KEY NEEDED (public, scraped directly)
# Greenhouse   → NO KEY NEEDED (public API)
# Lever        → NO KEY NEEDED (public API)
# How many jobs to fetch per refresh (keep 50-100 to avoid overloading)
JOBRIGHT_MAX_JOBS=80

# ── 4. AWS (only for production deployment) ─────
AWS_REGION=us-east-1
USE_DYNAMODB=false
DYNAMODB_TABLE=job-hunter-jobs
